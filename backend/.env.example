# PolyWorld Backend Environment

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=polyworld
DB_USER=polyworld
DB_PASSWORD=your_secure_password

# Server Configuration
PORT=3001
NODE_ENV=development

# Solana Configuration
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Program IDs (update with actual deployed addresses)
LAND_NFT_PROGRAM_ID=Land111111111111111111111111111111111111111
TREASURY_PROGRAM_ID=Treas11111111111111111111111111111111111111
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Treasury Authority (your wallet)
TREASURY_AUTHORITY=your_wallet_address

# Optional: API Keys for external services
HELIUS_API_KEY=your_helius_api_key
QUICKNODE_URL=your_quicknode_url
